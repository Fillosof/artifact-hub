# ─────────────────────────────────────────────────────────
# Artifact Hub — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────

# ── Turso (SQLite edge database) ──────────────────────────
# Get from: https://turso.tech → your database → "Connect" tab
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Clerk (authentication) ────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

# ── Vercel Blob (file storage) ────────────────────────────
# Get from: https://vercel.com → your project → Storage → Blob → "Create Store"
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token

# ── Anthropic (AI enrichment) ─────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── Internal enrichment shared secret ─────────────────────
# Generate with: openssl rand -hex 32
# Used to authenticate the internal /api/enrich route.
ENRICH_SECRET=change-me-to-a-long-random-secret

# ── Public application URL ────────────────────────────────
# Local development: http://localhost:3000
# Production: your Vercel deployment URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
